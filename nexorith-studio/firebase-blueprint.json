{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Co-founder", "Manager", "Designer", "Developer", "Intern", "Sales Intern", "CEO", "CTO"] },
        "permissions": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of granular permissions assigned to the user"
        },
        "avatar": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Potential client lead in the pipeline",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "value": { "type": "number" },
        "status": { "type": "string", "enum": ["New Lead", "Contacted", "Proposal Sent", "Closed Won", "Closed Lost"] },
        "assignedTo": { "type": "string", "description": "UID of the user assigned to this lead" },
        "followUpDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "array", "items": { "$ref": "#/entities/Note" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "company", "status"]
    },
    "Client": {
      "title": "Client",
      "description": "Converted lead now as a client",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "leadId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Onboarding", "Paused", "Completed"] },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Pending", "Overdue"] },
        "ownerId": { "type": "string", "description": "Account manager/Owner UID" },
        "assignedMember": { "type": "string" },
        "totalDealValue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A task linked to a lead or client",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "relatedTo": { "type": "string", "enum": ["lead", "client"] },
        "relatedId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["todo", "in_progress", "done"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "assignedTo", "relatedTo", "relatedId", "status"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Structured log of user actions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "entity": { "type": "string" },
        "entityId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      }
    },
    "Note": {
      "title": "Note",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Sent", "Paid", "Void"] },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "relatedTo": { "type": "string", "description": "Client ID or Project ID if applicable" },
        "recordedBy": { "type": "string" }
      },
      "required": ["type", "amount", "date", "recordedBy"]
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "target": { "type": "string" },
        "readBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "leads": {
      "schema": "Lead",
      "description": "Collection of leads"
    },
    "clients": {
      "schema": "Client",
      "description": "Collection of clients"
    },
    "invoices": {
      "schema": "Invoice",
      "description": "Collection of financial records"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Collection of income and expense transactions"
    },
    "notifications": {
      "schema": "Notification",
      "description": "Collection of system and targeted alerts"
    },
    "tasks": {
      "schema": "Task",
      "description": "Collection of tasks for team management"
    },
    "activityLogs": {
      "schema": "ActivityLog",
      "description": "Historical audit log of system events"
    }
  }
}
